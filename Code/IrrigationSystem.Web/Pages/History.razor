@page "/history"
@layout MainLayout
@inject ISensorDataService DataService

<PageTitle>History - Irrigation System</PageTitle>

<div class="history-page">
    <h3>Sensor History</h3>

    <div class="filters">
        <label>
            Zone:
            <select @bind="SelectedZoneId">
                <option value="1">Zone 1</option>
                <option value="2">Zone 2</option>
                <option value="3">Zone 3</option>
            </select>
        </label>

        <label>
            Time Range:
            <select @bind="TimeRangeHours" @bind:after="LoadHistory">
                <option value="6">Last 6 Hours</option>
                <option value="12">Last 12 Hours</option>
                <option value="24">Last 24 Hours</option>
                <option value="72">Last 3 Days</option>
                <option value="168">Last Week</option>
            </select>
        </label>

        <button class="btn-refresh" @onclick="LoadHistory">Refresh</button>
    </div>

    @if (IsLoading)
    {
        <p>Loading data...</p>
    }
    else if (HistoryData.Count == 0)
    {
        <p>No data available for this time range.</p>
    }
    else
    {
        <div class="charts-grid">

            <div class="chart-card">
                <h4>Moisture %</h4>
                <RadzenChart Style="height: 300px; margin-bottom: 30px;">
                    <RadzenLineSeries Data="@ChartData"
                                      CategoryProperty="RecordedAt"
                                      ValueProperty="Moisture"
                                      Title="Moisture"
                                      Stroke="#FF6B35"
                                      StrokeWidth="3">
                        <RadzenMarkers MarkerType="MarkerType.Circle" Fill="#FF6B35" Size="6" />
                    </RadzenLineSeries>

                    <RadzenCategoryAxis FormatString="{0:HH:mm}" />
                    <RadzenValueAxis Min="0" Max="100">
                        <RadzenGridLines Visible="true" />
                    </RadzenValueAxis>
                </RadzenChart>
            </div>

            <div class="chart-card">
                <h4>Temperature °C</h4>
                <RadzenChart Style="height: 300px; margin-bottom: 30px;">
                    <RadzenLineSeries Data="@ChartData"
                                      CategoryProperty="RecordedAt"
                                      ValueProperty="Temperature"
                                      Title="Temperature"
                                      Stroke="#DC143C"
                                      StrokeWidth="3">
                        <RadzenMarkers MarkerType="MarkerType.Circle" Fill="#DC143C" Size="6" />
                    </RadzenLineSeries>

                    <RadzenCategoryAxis FormatString="{0:HH:mm}" />
                    <RadzenValueAxis Min="0" Max="40">
                        <RadzenGridLines Visible="true" />
                    </RadzenValueAxis>
                </RadzenChart>
            </div>

            <div class="chart-card">
                <h4>Humidity %</h4>
                <RadzenChart Style="height: 300px; margin-bottom: 30px;">
                    <RadzenLineSeries Data="@ChartData"
                                      CategoryProperty="RecordedAt"
                                      ValueProperty="Humidity"
                                      Title="Humidity"
                                      Stroke="#4169E1"
                                      StrokeWidth="3">
                        <RadzenMarkers MarkerType="MarkerType.Circle" Fill="#4169E1" Size="6" />
                    </RadzenLineSeries>

                    <RadzenCategoryAxis FormatString="{0:HH:mm}" />
                    <RadzenValueAxis Min="0" Max="100">
                        <RadzenGridLines Visible="true" />
                    </RadzenValueAxis>
                </RadzenChart>
            </div>

        </div>

        <div class="stats-summary">
            <h4>Summary Statistics</h4>
            <table class="table table-striped">
                <tbody>
                    <tr>
                        <td><strong>Avg Moisture:</strong></td>
                        <td>@HistoryData.Average(d => d.Moisture ?? 0).ToString("F1")%</td>
                    </tr>
                    <tr>
                        <td><strong>Min Moisture:</strong></td>
                        <td>@HistoryData.Min(d => d.Moisture ?? 0).ToString("F1")%</td>
                    </tr>
                    <tr>
                        <td><strong>Max Moisture:</strong></td>
                        <td>@HistoryData.Max(d => d.Moisture ?? 0).ToString("F1")%</td>
                    </tr>
                    <tr>
                        <td><strong>Data Points:</strong></td>
                        <td>@HistoryData.Count</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="data-table">
            <h4>Raw Data</h4>
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Moisture (%)</th>
                        <th>Temperature (°C)</th>
                        <th>Humidity (%)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var data in HistoryData.OrderByDescending(d => d.RecordedAt))
                    {
                        <tr>
                            <td>@data.RecordedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(data.Moisture?.ToString("F1") ?? "N/A")</td>
                            <td>@(data.Temperature?.ToString("F1") ?? "N/A")</td>
                            <td>@(data.Humidity?.ToString("F1") ?? "N/A")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<SensorReading> HistoryData = new();
    private List<SensorReading> ChartData = new();
    private int SelectedZoneId = 1;
    private int TimeRangeHours = 24;
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        IsLoading = true;

        HistoryData = await DataService.GetZoneHistoryAsync(SelectedZoneId, TimeRangeHours);

        ChartData = new List<SensorReading>(HistoryData);

        if (ChartData.Count > 0)
        {
            var first = ChartData.First();

            ChartData.Insert(0, new SensorReading
            {
                RecordedAt = first.RecordedAt.AddMinutes(-1),
                Moisture = first.Moisture,
                Temperature = first.Temperature,
                Humidity = first.Humidity
            });
        }

        IsLoading = false;
    }
}
